# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# --- Instagram ---------------------------------------------------
INSTALOADER_USERNAME=seu_usuario

# Caminho para a pasta que contém o arquivo de sessão do Instaloader.
# A sessão deve ser gerada dentro do container (veja o README, seção 2).
# Use o caminho ABSOLUTO da pasta session/ criada na raiz do projeto:
#
#   Windows:  C:\Users\SeuUsuario\Documents\GitHub\seu-projeto\session
#   Linux:    /home/seu_usuario/seu-projeto/session
#   Mac:      /Users/seu_usuario/seu-projeto/session
#
# Não use caminhos relativos (.\session ou ./session) — o Docker
# no Windows não resolve caminhos relativos em volumes corretamente.
INSTALOADER_SESSION_PATH=C:\Users\SeuUsuario\Documents\GitHub\seu-projeto\session

# --- OpenStreetMap (.pbf) ---------------------------------------
# Baixe em: https://download.geofabrik.de/south-america/brazil.html
# Use o caminho ABSOLUTO do diretório onde o .pbf está salvo,
# ou . para apontar para a raiz do projeto (se o arquivo estiver lá).
OSM_PBF_DIR=.
OSM_PBF_FILE=espirito-santo-latest.osm.pbf

# --- Bounding box -----------------------------------------------
# Formato: lat_min,lon_min,lat_max,lon_max
# Padrao abaixo = Grande Vitoria ES
BBOX=-20.5,-40.5,-20.1,-40.1

# --- Modo de resolução de locations ----------------------------
# osm_name  = resolve por nome via OSM + fbsearch/places (padrão)
# geo_grid  = varre grade de coordenadas via location_search (Bellingcat)
LOCATION_RESOLVE_MODE=osm_name

# Cookie do Instagram (necessário apenas para LOCATION_RESOLVE_MODE=geo_grid)
# Como obter: abra o Instagram no browser → DevTools (F12) → Network
#   → clique em qualquer requisição → Request Headers → copie o valor de "cookie"
IG_COOKIE=

# Espaçamento da grade em km (apenas para geo_grid)
# 1.0 = ~1600 pontos para Grande Vitória | 0.5 = ~6400 pontos (mais completo)
GEO_GRID_STEP_KM=1.0

# --- Modo de coleta ---------------------------------------------
# both     = coleta por locations (OSM) e por hashtags (padrao)
# location = somente coleta por locations
# hashtag  = somente coleta por hashtags
COLLECT_MODE=both

# --- Periodo de coleta -----------------------------------------
# Posts anteriores a esta data sao ignorados (formato: YYYY-MM-DD)
STOP_DATE=2026-01-01

# --- Geracao automatica de hashtags -----------------------------
# true  = gera hashtags a partir dos nomes dos POIs do .pbf (padrao)
# false = usa apenas a lista fixa do hashtags.txt
HASHTAG_AUTO_GENERATE=true

# --- Banco de dados ---------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=instagram
DB_PORT=5432
